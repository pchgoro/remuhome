{
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/schedule-refresh",
      "schedule": "*/30 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/((?!api/).+)",
      "destination": "/public/$1"
    }
  ]
}
